---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MusicPlayer from "../../components/MusicPlayer.astro";
import { songs } from "../../data/songs";
import { site } from "../../data/site";

export function getStaticPaths() {
  return songs.map((song) => ({
    params: { slug: song.slug },
    props: { song },
  }));
}

const { song } = Astro.props;

const hasStreaming = Boolean(song.hlsUrl);
const coverUrl = `${site.assetsUrl}${song.cover}`;

const currentIndex = songs.findIndex((item) => item.slug === song.slug);
const previousSong = currentIndex > 0 ? songs[currentIndex - 1] : null;
const nextSong = currentIndex < songs.length - 1 ? songs[currentIndex + 1] : null;


const pageTitle = `${song.title} | Música | Mario Molina`;
const pageDescription = `${song.description} ${song.genre} · ${song.bpm} BPM · ${song.duration}.`;
const pageImage = coverUrl;

const songSchema = {
  "@context": "https://schema.org",
  "@type": "MusicRecording",
  name: song.title,
  byArtist: {
    "@type": "Person",
    name: site.name,
  },
  genre: song.genre,
  duration: song.duration,
  image: coverUrl,
  url: `${site.url}/musica/${song.slug}`,
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={pageImage}
  type="music.song"
>
  <script type="application/ld+json" set:html={JSON.stringify(songSchema)} />
  <main>
    <section class="song-detail">
      <div class="song-detail-cover real-image" style={`background-image: url('${coverUrl}')`}>
        <div class="vinyl-large"></div>
        <span>{song.title}</span>
      </div>

      <div class="song-detail-content">
        <p class="kicker">Canción</p>

        <h1 class="page-title">{song.title}</h1>

        <p class="page-description">
          {song.story}
        </p>

        <div class="music-info-grid">
          <div>
            <strong>Género</strong>
            <span>{song.genre}</span>
          </div>

          <div>
            <strong>Duración</strong>
            <span>{song.duration}</span>
          </div>

          <div>
            <strong>BPM</strong>
            <span>{song.bpm}</span>
          </div>

          <div>
            <strong>Estado</strong>
            <span>{song.status}</span>
          </div>
        </div>

        <MusicPlayer title={song.title} hlsUrl={song.hlsUrl} />

        <div class="actions">
          <a href={song.sunoUrl} target="_blank" rel="noopener noreferrer" class="btn">
            Escuchar en Suno
          </a>

          <a href="/musica" class="btn btn-secondary">
            Volver a música
          </a>
        </div>
        <nav class="song-navigation" aria-label="Navegación entre canciones">
  {previousSong ? (
    <a href={`/musica/${previousSong.slug}`} class="song-nav-card">
      <small>Anterior</small>
      <strong>{previousSong.title}</strong>
    </a>
  ) : (
    <span class="song-nav-card disabled">
      <small>Anterior</small>
      <strong>No hay canción anterior</strong>
    </span>
  )}

  {nextSong ? (
    <a href={`/musica/${nextSong.slug}`} class="song-nav-card">
      <small>Siguiente</small>
      <strong>{nextSong.title}</strong>
    </a>
  ) : (
    <span class="song-nav-card disabled">
      <small>Siguiente</small>
      <strong>No hay más canciones</strong>
    </span>
  )}
</nav>
      </div>
    </section>

    <section class="lyrics-section">
      <p class="kicker">Letra</p>

      <div class="lyrics-box">
        {song.lyrics.map((line: string) => (
          line === "" ? <br /> : <p>{line}</p>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>