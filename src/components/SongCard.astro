---
import { site } from "../data/site";

const { song } = Astro.props;

const coverUrl = `${site.assetsUrl}${song.cover}`;
const hasStreaming = Boolean(song.hlsUrl);

const searchText = [
  song.title,
  song.genre,
  song.status,
  song.bpm,
  song.duration,
  song.description,
].join(" ").toLowerCase();
---

<article
  class="song-card"
  data-song-card
  data-streaming={hasStreaming ? "true" : "false"}
  data-featured={song.featured ? "true" : "false"}
  data-genre={song.genre.toLowerCase()}
  data-search={searchText}
>
  <div class="song-cover image-shell">
    <img
      src={coverUrl}
      alt={`Portada de ${song.title}`}
      loading="lazy"
      decoding="async"
    />

    <div class="vinyl-circle"></div>

    <div class="song-cover-badges">
      {hasStreaming ? (
        <span class="streaming-badge">Streaming propio</span>
      ) : (
        <span class="pending-badge">Próximamente</span>
      )}
    </div>

    <span>{song.title}</span>
  </div>

  <div class="song-content">
    <div class="song-meta">
      <span>{song.genre}</span>
      <span>{song.duration}</span>
    </div>

    <h2>{song.title}</h2>

    <p>{song.description}</p>

    <div class="song-status">
      <span>{hasStreaming ? "Disponible aquí" : song.status}</span>
      <span>{song.bpm} BPM</span>
    </div>

    <div class="actions">
      <a href={`/musica/${song.slug}`} class="btn">
        {hasStreaming ? "Escuchar aquí" : "Ver canción"}
      </a>

      <a href={song.sunoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
        Suno
      </a>
    </div>
  </div>
</article>