---
import { site } from "../data/site";

const { pack } = Astro.props;

const message = encodeURIComponent(
  `Hola Mario, quiero información sobre el bono: ${pack.name} (${pack.price}€).`
);

const whatsappUrl = `https://wa.me/${site.phone}?text=${message}`;
---

<article class="pack-card">
  <div class="pack-price">{pack.price}€</div>

  <h2>{pack.name}</h2>

  <p>{pack.description}</p>

  <ul>
    {pack.includes.map((item: string) => (
      <li>{item}</li>
    ))}
  </ul>

  <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn wellness-btn">
    Pedir información
  </a>
</article>