---
import { site } from "../data/site";

const { app } = Astro.props;

const hasApk = Boolean(app.apkUrl && app.apkUrl !== "#");
const imageUrl = `${site.assetsUrl}${app.image}`;
---

<article class="app-card">
  <div class="app-image real-image" style={`background-image: url('${imageUrl}')`}>
    <span>{app.title}</span>
  </div>

  <div class="app-content">
    <div class="app-meta">
      <span>{app.status}</span>
      <span>{app.version}</span>
    </div>

    <h2>{app.title}</h2>

    <p>{app.description}</p>

    <div class="badge-row">
      {app.stack.map((tech: string) => (
        <span class="badge">{tech}</span>
      ))}
    </div>

    <div class="actions">
      <a href={`/apps/${app.slug}`} class="btn">
        Ver proyecto
      </a>

      {hasApk ? (
        <a href={app.apkUrl} class="btn btn-secondary">
          Descargar APK
        </a>
      ) : (
        <span class="btn-disabled">
          APK próximamente
        </span>
      )}
    </div>
  </div>
</article>